# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aegis
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Environment
ENVIRONMENT=development

# External Data Sources (for future use)
CHICAGO_DATA_API_URL=https://data.cityofchicago.org/resource/crimes.json
NYC_DATA_API_URL=https://data.cityofnewyork.us/resource/qgea-i56i.json

# Logging
LOG_LEVEL=INFO
