# Database Configuration (using SQLite for now - will switch to Supabase later)
DATABASE_URL=sqlite+aiosqlite:///./aegis.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Environment
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
